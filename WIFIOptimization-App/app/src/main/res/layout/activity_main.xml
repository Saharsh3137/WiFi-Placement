<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#090F1C"
    android:keepScreenOn="true">

    <!-- ═══════════════════════════════════════════════════════════
         HEADER BAR
         ═══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="@drawable/bg_header"
        android:elevation="10dp"
        android:paddingStart="18dp"
        android:paddingEnd="14dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Tiny cyan pulse dot -->
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_dot_cyan"
            android:layout_marginEnd="10dp"/>

        <!-- App title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="WiFi Mesh Monitor"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#E8F4FF"/>

        <!-- Demo label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Demo"
            android:textColor="#7A9CC4"
            android:textSize="13sp"
            android:layout_marginEnd="4dp"/>

        <Switch
            android:id="@+id/demoModeSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:thumbTint="#00C6FF"
            android:trackTint="#1A2C48"/>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════
         MAIN CONTENT  (between header and bottom nav)
         ═══════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerLayout"
        android:layout_above="@id/bottomNav">

        <!-- ┌──────────────────────────────────────────────────────┐
             │  TAB 1 – DASHBOARD                                   │
             └──────────────────────────────────────────────────────┘ -->
        <ScrollView
            android:id="@+id/tabDashboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="14dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── Connection Card ───────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="18dp"
                    android:layout_marginBottom="14dp"
                    android:elevation="4dp">

                    <!-- Status + Setup button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BLUETOOTH STATUS"
                                android:textColor="#4A6A9A"
                                android:textSize="10sp"
                                android:letterSpacing="0.12"/>

                            <TextView
                                android:id="@+id/statusText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Disconnected"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="#FF5252"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <!-- AppCompatButton respects android:background, no Material tint override -->
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/toggleWifiBtn"
                            style="@style/Widget.AppCompat.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="⚙  Setup"
                            android:textSize="12sp"
                            android:background="@drawable/bg_btn_secondary"
                            android:textColor="#00C6FF"
                            android:visibility="gone"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"/>
                    </LinearLayout>

                    <!-- Connect / Disconnect buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/connectButton"
                            style="@style/Widget.AppCompat.Button"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="⚡  Connect"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_btn_primary"
                            android:textColor="#FFFFFF"/>

                        <Space android:layout_width="10dp" android:layout_height="wrap_content"/>

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/disconnectButton"
                            style="@style/Widget.AppCompat.Button"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="✕  Disconnect"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_btn_danger"
                            android:textColor="#FFFFFF"
                            android:visibility="gone"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── WiFi Credentials Card (hidden until BT connected) ── -->
                <LinearLayout
                    android:id="@+id/wifiCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="18dp"
                    android:layout_marginBottom="14dp"
                    android:elevation="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DEPLOY NETWORK"
                        android:textColor="#00C6FF"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="14dp"/>

                    <EditText
                        android:id="@+id/ssidInput"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="WiFi Network Name"
                        android:textColor="#E8F4FF"
                        android:textColorHint="#4A6A9A"
                        android:background="@drawable/bg_edittext"
                        android:textSize="14sp"
                        android:inputType="text"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginBottom="10dp"/>

                    <EditText
                        android:id="@+id/passInput"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="WiFi Password"
                        android:textColor="#E8F4FF"
                        android:textColorHint="#4A6A9A"
                        android:background="@drawable/bg_edittext"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginBottom="14dp"/>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/sendWifiBtn"
                        style="@style/Widget.AppCompat.Button"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="🚀  Push Credentials to Nodes"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_btn_primary"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <!-- ── Network Health Card ──────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="18dp"
                    android:layout_marginBottom="14dp"
                    android:elevation="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NETWORK HEALTH SCORE"
                        android:textColor="#4A6A9A"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="14dp"/>

                    <!-- Score badge + node status side-by-side -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <!-- Circular quality badge -->
                        <!-- qualityText is set by Java as "46/100" so we fill that single view -->
                        <FrameLayout
                            android:layout_width="116dp"
                            android:layout_height="116dp"
                            android:background="@drawable/bg_quality_badge">

                            <TextView
                                android:id="@+id/qualityText"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:text="--"
                                android:textColor="#FFD740"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:autoSizeTextType="uniform"
                                android:autoSizeMinTextSize="14sp"
                                android:autoSizeMaxTextSize="30sp"
                                android:padding="12dp"/>
                        </FrameLayout>

                        <!-- Node status list -->
                        <TextView
                            android:id="@+id/nodeStatusText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:text="Node 1: 🔴 Offline&#10;Node 2: 🔴 Offline&#10;Node 3: 🔴 Offline"
                            android:lineSpacingExtra="6dp"
                            android:textColor="#C8DCF8"
                            android:textSize="12.5sp"/>
                    </LinearLayout>

                    <!-- Glowing divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@drawable/bg_divider"
                        android:layout_marginBottom="14dp"/>

                    <!-- Metric rows (Java sets verbose strings, so use full-width rows) -->

                    <!-- RSSI -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="18dp"
                            android:background="#00C6FF"
                            android:layout_marginEnd="12dp"/>

                        <TextView
                            android:id="@+id/rssiText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Avg RSSI: -- dBm"
                            android:textColor="#00C6FF"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Latency -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="18dp"
                            android:background="#A4F642"
                            android:layout_marginEnd="12dp"/>

                        <TextView
                            android:id="@+id/latencyText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Avg Ping: -- ms"
                            android:textColor="#A4F642"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Packet Loss -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="18dp"
                            android:background="#FFD740"
                            android:layout_marginEnd="12dp"/>

                        <TextView
                            android:id="@+id/packetLossText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Avg Loss: -- %"
                            android:textColor="#FFD740"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Session Card ───────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="18dp"
                    android:layout_marginBottom="24dp"
                    android:elevation="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SESSION"
                        android:textColor="#4A6A9A"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="12dp"/>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/resetStatsBtn"
                        style="@style/Widget.AppCompat.Button"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:text="↺  Clear Session Data"
                        android:textSize="13sp"
                        android:background="@drawable/bg_btn_secondary"
                        android:textColor="#7A9CC4"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- ┌──────────────────────────────────────────────────────┐
             │  TAB 2 – ANALYTICS                                   │
             └──────────────────────────────────────────────────────┘ -->
        <ScrollView
            android:id="@+id/tabAnalytics"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:padding="14dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- RSSI chart card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="14dp"
                    android:layout_marginBottom="14dp"
                    android:elevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="14dp"
                            android:background="#00C6FF"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="SIGNAL STRENGTH — RSSI"
                            android:textColor="#8AABCF"
                            android:textSize="11sp"
                            android:letterSpacing="0.08"/>
                    </LinearLayout>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/rssiChart"
                        android:layout_width="match_parent"
                        android:layout_height="190dp"/>
                </LinearLayout>

                <!-- Latency chart card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="14dp"
                    android:layout_marginBottom="14dp"
                    android:elevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="14dp"
                            android:background="#A4F642"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="LATENCY / PING"
                            android:textColor="#8AABCF"
                            android:textSize="11sp"
                            android:letterSpacing="0.08"/>
                    </LinearLayout>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/latencyChart"
                        android:layout_width="match_parent"
                        android:layout_height="190dp"/>
                </LinearLayout>

                <!-- Packet loss chart card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="14dp"
                    android:layout_marginBottom="24dp"
                    android:elevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="14dp"
                            android:background="#FFD740"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="PACKET LOSS"
                            android:textColor="#8AABCF"
                            android:textSize="11sp"
                            android:letterSpacing="0.08"/>
                    </LinearLayout>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/packetChart"
                        android:layout_width="match_parent"
                        android:layout_height="190dp"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- ┌──────────────────────────────────────────────────────┐
             │  TAB 3 – PLACEMENT / HEATMAP                         │
             └──────────────────────────────────────────────────────┘ -->
        <LinearLayout
            android:id="@+id/tabPlacement"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingTop="12dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <!-- Gradient calibrate CTA button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/startCalibBtn"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="⚡  GENERATE HEATMAP"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:background="@drawable/bg_calibrate_btn"
                android:textColor="#FFFFFF"/>

            <!-- Status + readout info card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/calibStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ready for dynamic mapping."
                    android:textAlignment="center"
                    android:textColor="#A0BFDF"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@drawable/bg_divider"
                    android:layout_marginBottom="8dp"/>

                <!-- Static header for distance readout -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📡 ROUTER DISTANCES"
                    android:textColor="#4A6A9A"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="4dp"/>

                <!-- Values set by Java: "N1: 0.6m  ·  N2: 1.4m  ·  N3: 3.8m" -->
                <TextView
                    android:id="@+id/distanceReadoutText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Awaiting mesh data…"
                    android:textAlignment="center"
                    android:textColor="#A4F642"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Heatmap canvas fills remaining space -->
            <FrameLayout
                android:id="@+id/heatmapContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#090F1C"/>

        </LinearLayout>
    </FrameLayout>

    <!-- ═══════════════════════════════════════════════════════════
         BOTTOM NAVIGATION  (AppCompatButton — no Material tint)
         ═══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:elevation="16dp"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/navDash"
            style="@style/Widget.AppCompat.Button"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="📊 Dashboard"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@android:color/transparent"
            android:textColor="#00C6FF"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/navAnalytics"
            style="@style/Widget.AppCompat.Button"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="📈 Analytics"
            android:textSize="11sp"
            android:background="@android:color/transparent"
            android:textColor="#4A6A9A"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/navPlacement"
            style="@style/Widget.AppCompat.Button"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="📡 Placement"
            android:textSize="11sp"
            android:background="@android:color/transparent"
            android:textColor="#4A6A9A"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

    </LinearLayout>

</RelativeLayout>