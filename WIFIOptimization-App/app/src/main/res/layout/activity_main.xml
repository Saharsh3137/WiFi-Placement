<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0B0F1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wireless Network Monitor"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#00E5FF"
            android:layout_marginBottom="12dp"/>

        <!-- STATUS -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disconnected"
            android:textSize="16sp"
            android:textColor="#FF5252"
            android:layout_marginBottom="8dp"/>

        <!-- NODE STATUS -->
        <TextView
            android:id="@+id/nodeStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nodes: --"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <!-- METRICS -->
        <TextView
            android:id="@+id/rssiText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RSSI: --"
            android:textSize="16sp"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/latencyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Latency: --"
            android:textSize="16sp"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/packetLossText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loss: --"
            android:textSize="16sp"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/qualityText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quality: --"
            android:textSize="15sp"
            android:textColor="#FFD740"
            android:layout_marginBottom="12dp"/>

        <!-- BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/connectButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Connect"
                android:textSize="14sp"
                android:backgroundTint="#A4F642"
                android:textColor="#000000"/>

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/disconnectButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Disconnect"
                android:textSize="14sp"
                android:backgroundTint="#F63D3D"
                android:textColor="#000000"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- WIFI INPUT -->
        <LinearLayout
            android:id="@+id/wifiLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:background="#1A2235">

            <EditText
                android:id="@+id/ssidInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="WiFi Name"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:backgroundTint="#00E5FF"/>

            <EditText
                android:id="@+id/passInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:hint="WiFi Password"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:inputType="textPassword"
                android:backgroundTint="#00E5FF"/>

            <Button
                android:id="@+id/sendWifiBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="Send WiFi to Nodes"
                android:textSize="14sp"
                android:backgroundTint="#00E5FF"
                android:textColor="#000000"/>
        </LinearLayout>

        <!-- NODE SELECT -->

        <!-- GRAPHS -->
        <TextView
            android:text="RSSI (dBm):"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/rssiChart"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="16dp"/>

        <TextView
            android:text="Latency (ms):"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/latencyChart"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="12dp"/>

        <TextView
            android:text="Packet Loss (%):"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/packetChart"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="12dp"/>

    </LinearLayout>
</ScrollView>